# --- Internal AI Context ---
.gemini/
.codex/
skills/
*.skill
.worktrees/

# --- CCUS maintenance agent product workspace ---
agent/*
!agent/ccus-ai-agent/

agent/ccus-ai-agent/*
!agent/ccus-ai-agent/AGENTS.md
!agent/ccus-ai-agent/SKILL.md
!agent/ccus-ai-agent/DESIGN.md
!agent/ccus-ai-agent/ARCHITECTURE.md
!agent/ccus-ai-agent/METHODOLOGY.md
!agent/ccus-ai-agent/RUNBOOK.md
!agent/ccus-ai-agent/SAFETY.md
!agent/ccus-ai-agent/archive/
!agent/ccus-ai-agent/archive/*.md
!agent/ccus-ai-agent/migrations/
!agent/ccus-ai-agent/migrations/*.md
!agent/ccus-ai-agent/logic/
!agent/ccus-ai-agent/governance/

# Track the canonical CLI, active logic, and logic guidance.
agent/ccus-ai-agent/logic/*
!agent/ccus-ai-agent/logic/*.mjs
!agent/ccus-ai-agent/logic/README.md

# Keep schema and the active master database; ignore locks and ambiguous snapshots.
!agent/ccus-ai-agent/db/
agent/ccus-ai-agent/db/*
!agent/ccus-ai-agent/db/schema.sql
!agent/ccus-ai-agent/db/ccus_master.sqlite
agent/ccus-ai-agent/db/.lock
agent/ccus-ai-agent/db/*.tmp
agent/ccus-ai-agent/db/*backup*.sqlite
agent/ccus-ai-agent/db/*snapshot*.sqlite

# Governance configuration is tracked; reports and legacy archives are generated/history.
agent/ccus-ai-agent/governance/*
!agent/ccus-ai-agent/governance/README.md
!agent/ccus-ai-agent/governance/audit_thresholds.json
agent/ccus-ai-agent/governance/reports/*
agent/ccus-ai-agent/governance/archive/*

# --- Background Tasks ---
tasks/

# --- Absolute Entry Points (Must be tracked) ---
!agent.md
!README.md
!README.zh.md
