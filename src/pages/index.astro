---
import Layout from '../layouts/Layout.astro';
import HomepageHero from '../components/HomepageHero.astro';
import WorldMapNav from '../components/WorldMapNav.astro';
import CapacityTrend from '../components/CapacityTrend.astro';
import ProjectLandscape from '../components/ProjectLandscape.astro';
import DatasetVersion from '../components/DatasetVersion.astro';
import { getCollection } from 'astro:content';
import '../styles/home-refinement.css';
import '../styles/home-final-qa.css';

const policies = await getCollection('policies_zh');
const policyCount = policies.length;
---

<Layout
  title="CCUS 政策与设施全球数据库"
  description="全球 CCUS 政策、设施、项目记录能力与治理对比数据库。"
  pageClass="home-page-shell home-page--zh"
>
  <div class="home-page-content py-8 sm:py-10">
    <HomepageHero lang="zh" />

    <CapacityTrend />

    <ProjectLandscape lang="zh" />

    <section class="home-map-section" aria-labelledby="home-map-title">
      <header class="home-section-head">
        <div class="home-section-copy">
          <p class="home-section-kicker">全球政策导航</p>
          <h2 id="home-map-title" class="home-section-title">政策准入控制台</h2>
          <p class="home-section-description">
            点击高亮活跃区域，快速查看关键政策框架、准入要求、激励机制与项目部署状态。
          </p>
        </div>
        <div
          class="home-policy-count"
          aria-label={`当前已纳入 ${policyCount} 项核心政策`}
        >
          当前已纳入 <strong>{policyCount}</strong> 项核心政策
        </div>
      </header>
      <WorldMapNav lang="zh" />
    </section>

    <section class="home-feature-grid" aria-label="平台核心能力">
      <article class="home-feature-card" data-accent="teal">
        <div class="home-feature-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path>
          </svg>
        </div>
        <div>
          <h3 class="home-feature-title">权威数据源</h3>
          <p class="home-feature-description">
            整合 IEA CCUS Projects Database 2026、GCCSI
            与各国政府公开信息，并通过统一数据治理流程维护来源、口径与更新状态。
          </p>
          <div class="home-feature-meta">已核验来源治理</div>
        </div>
      </article>

      <article class="home-feature-card" data-accent="blue">
        <div class="home-feature-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
            <path d="M22 12A10 10 0 0 0 12 2v10z"></path>
          </svg>
        </div>
        <div>
          <h3 class="home-feature-title">可视化分析</h3>
          <p class="home-feature-description">
            通过交互式地图、项目能力趋势与多维政策对比，识别治理强度、设施规模和区域部署之间的结构性关系。
          </p>
          <div class="home-feature-meta">交互式情报分析</div>
        </div>
      </article>

      <article class="home-feature-card" data-accent="indigo">
        <div class="home-feature-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <div>
          <h3 class="home-feature-title">行业精准对标</h3>
          <p class="home-feature-description">
            面向制氢、电力、钢铁等重点行业，关联政策工具与设施记录，为区域准入、投资判断和治理机制设计提供结构化参照。
          </p>
          <div class="home-feature-meta">行业专项对标</div>
        </div>
      </article>
    </section>
  </div>

  <div class="mx-auto max-w-6xl px-4 pb-8">
    <DatasetVersion lang="zh" />
  </div>
</Layout>
