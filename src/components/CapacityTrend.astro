---
import { getCollection } from 'astro:content';

const lang = Astro.currentLocale || 'zh';
const facilities = await getCollection(
  lang === 'en' ? 'facilities_en' : 'facilities_zh'
);
type Facility = (typeof facilities)[number];

const startYear = 1970;
const endYear = 2040;
const pipelineStatuses = new Set<string>([
  'planned',
  'operational',
  'under-construction',
]);
const committedStatuses = new Set<string>(['operational', 'under-construction']);
const typeOptions = [
  { id: 'capture', label: 'Capture' },
  { id: 'transport', label: 'Transport' },
  { id: 'ts', label: 'T&S' },
  { id: 'storage', label: 'Storage' },
  { id: 'full-chain', label: 'Full chain' },
  { id: 'ccu', label: 'CCU' },
] as const;

type TypeId = (typeof typeOptions)[number]['id'];

type ChartPoint = {
  year: number;
  operational: number;
  pipeline: number;
};

type CapacityRecord = {
  year: number;
  typeId: TypeId | null;
  capacity: number;
  committed: boolean;
  pipeline: boolean;
};

const text = {
  totalTitle:
    lang === 'zh'
      ? '全球项目记录能力 (2040估)'
      : 'Global Project-Record Capacity (2040 Est.)',
  totalNote:
    lang === 'zh'
      ? 'Planned、Operational 与 Under construction 项目记录能力累计；排除 Cancelled / Decommissioned / Suspended。'
      : 'Cumulative project-record capacity for Planned, Operational and Under construction records; Cancelled / Decommissioned / Suspended excluded.',
  chartTitle:
    lang === 'zh'
      ? '全球 CCUS 项目记录能力增长趋势'
      : 'CCUS Project-Record Capacity Growth',
  committedLabel:
    lang === 'zh'
      ? '确定性能力（在运+在建）'
      : 'Committed (Operational + Under construction)',
  pipelineLabel:
    lang === 'zh'
      ? '公开管线（规划+在运+在建）'
      : 'Pipeline (Planned + Operational + Under construction)',
  typeFilterTitle: lang === 'zh' ? '类型' : 'Types',
  chartNote:
    lang === 'zh'
      ? '注：本图采用 project-record 口径，按 operation → FID → announcement 年份累计 Planned、Operational、Under construction 项目记录能力；Cancelled、Decommissioned、Suspended 被排除。筛选项覆盖 capture、transport、T&S、storage、full-chain、CCU。数值为跨类型项目记录能力加总，不代表净可交付捕集能力或净封存能力。'
      : 'Note: This chart uses a project-record methodology, accumulating Planned, Operational and Under construction records by operation → FID → announcement year; Cancelled, Decommissioned and Suspended records are excluded. The type filter covers capture, transport, T&S, storage, full-chain and CCU. Values aggregate project-record capacity across selected types and should not be interpreted as net deliverable capture or storage capacity.',
};

const parseYear = (value: unknown): number | null => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value !== 'string') return null;

  const match = value.match(/\d{4}/);
  return match ? Number.parseInt(match[0], 10) : null;
};

const normalizeStatus = (status: string | undefined): string => {
  const value = (status || '').trim().toLowerCase();

  if (value === 'operational' || value === '运行中') return 'operational';
  if (value === 'under construction' || value === '建设中') return 'under-construction';
  if (value === 'planned' || value === '计划中' || value === '规划中') return 'planned';
  if (value === 'cancelled' || value === '已取消') return 'cancelled';
  if (value === 'decommissioned' || value === '已退役') return 'decommissioned';
  if (
    value === 'suspended' ||
    value === '暂停' ||
    value === '已暂停' ||
    value === '已中止'
  ) {
    return 'suspended';
  }

  return value;
};

const normalizeType = (type: string | undefined): TypeId | null => {
  const value = (type || '').trim().toLowerCase();

  if (value === 'capture' || value === '捕集' || value === '碳捕集') {
    return 'capture';
  }
  if (
    value === 'transport' ||
    value === 'transportation' ||
    value === '运输' ||
    value === '碳运输'
  ) {
    return 'transport';
  }
  if (
    value === 't&s' ||
    value === 'transport & storage' ||
    value === 'transport and storage' ||
    value === '运输与封存' ||
    value === '运输和封存'
  ) {
    return 'ts';
  }
  if (
    value === 'storage' ||
    value === '封存' ||
    value === '储存' ||
    value === '碳封存'
  ) {
    return 'storage';
  }
  if (
    value === 'full chain' ||
    value === 'full-chain' ||
    value === '全链条' ||
    value === '全链' ||
    value === '全流程项目'
  ) {
    return 'full-chain';
  }
  if (value === 'ccu' || value === '利用' || value === '碳利用') return 'ccu';

  return null;
};

const capacity = (f: Facility): number => {
  const estimatedCapacity = f.data.estimatedCapacity || 0;
  if (estimatedCapacity > 0) return estimatedCapacity;

  const minCapacity = f.data.announcedCapacityMin || 0;
  const maxCapacity = f.data.announcedCapacityMax || 0;

  if (minCapacity && maxCapacity) return (minCapacity + maxCapacity) / 2;
  return minCapacity || maxCapacity || 0;
};

const projectRecordYear = (f: Facility): number | null =>
  parseYear(f.data.operation) ??
  parseYear(f.data.fid) ??
  parseYear(f.data.announcement);

const trendYears = Array.from(
  { length: endYear - startYear + 1 },
  (_, index) => startYear + index
);

const capacityRecords: CapacityRecord[] = facilities.flatMap((f: Facility) => {
  const year = projectRecordYear(f);
  const status = normalizeStatus(f.data.status);

  if (!year || year < startYear || year > endYear || !pipelineStatuses.has(status)) {
    return [];
  }

  return [
    {
      year,
      typeId: normalizeType(f.data.type),
      capacity: capacity(f),
      committed: committedStatuses.has(status),
      pipeline: true,
    },
  ];
});

const buildSeries = (records: CapacityRecord[]): ChartPoint[] => {
  let cumulativeCommitted = 0;
  let cumulativePipeline = 0;

  return trendYears.map((year) => {
    records.forEach((record) => {
      if (record.year !== year) return;
      if (record.committed) cumulativeCommitted += record.capacity;
      if (record.pipeline) cumulativePipeline += record.capacity;
    });

    return {
      year,
      operational: cumulativeCommitted,
      pipeline: cumulativePipeline,
    };
  });
};

const chartData = buildSeries(capacityRecords);
const typeChartData: Record<string, ChartPoint[]> = {};
typeOptions.forEach((option) => {
  typeChartData[option.id] = buildSeries(
    capacityRecords.filter((record) => record.typeId === option.id)
  );
});

const totalCapacity = (chartData.at(-1)?.pipeline || 0).toFixed(1);
const operationalFacilities = facilities.filter(
  (f: Facility) => normalizeStatus(f.data.status) === 'operational'
);
const operationalCount = operationalFacilities.length;
const operationalCapacity = operationalFacilities
  .reduce((acc: number, f: Facility) => acc + capacity(f), 0)
  .toFixed(1);

const constructionFacilities = facilities.filter(
  (f: Facility) => normalizeStatus(f.data.status) === 'under-construction'
);
const constructionCount = constructionFacilities.length;
const constructionCapacity = constructionFacilities
  .reduce((acc: number, f: Facility) => acc + capacity(f), 0)
  .toFixed(1);
---

<div data-capacity-trend class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
  <div class="lg:col-span-1 space-y-6">
    <div
