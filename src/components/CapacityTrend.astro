        </div>
      </aside>

      <div class="h-[300px] w-full relative">
        <div
          class="absolute inset-0 bg-gradient-to-t from-blue-500/5 to-transparent opacity-0 group-hover/chart:opacity-100 transition-opacity duration-1000 pointer-events-none rounded-xl"
        >
        </div>
        <canvas
          id="capacityChart"
          data-values={JSON.stringify(chartData)}
          data-type-series={JSON.stringify(typeChartData)}
