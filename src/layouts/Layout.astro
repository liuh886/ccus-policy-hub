---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
  pageClass?: string;
}

import { ui, defaultLang } from '../i18n/ui';
const lang = Astro.currentLocale || defaultLang;
const t = (key: keyof (typeof ui)['zh']) =>
  ui[lang as keyof typeof ui][key] || ui[defaultLang][key];
const normalizedPath =
  Astro.url.pathname.replace(/^\/ccus-policy-hub/, '').replace(/\/$/, '') ||
  '/';
const hideCompareDrawer =
  normalizedPath === '/' ||
  normalizedPath === '/en' ||
  normalizedPath === '/facilities' ||
  normalizedPath === '/en/facilities';

const { title, description, keywords, pageClass = '' } = Astro.props;
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import CompareDrawer from '../components/CompareDrawer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/interaction-controls.css';
import '../styles/light-editorial.css';
import '../styles/light-editorial-capacity.css';
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEO title={title} description={description} keywords={keywords} />
    <ClientRouter />
    <meta id="site-theme-color" name="theme-color" content="#f6f7f4" />
    <script is:inline>
      (() => {
        const STORAGE_KEY = 'theme';
        const preferences = new Set(['system', 'light', 'dark']);
        const media = window.matchMedia('(prefers-color-scheme: dark)');

        const getPreference = () => {
          const stored = window.localStorage.getItem(STORAGE_KEY);
          return preferences.has(stored) ? stored : 'system';
        };

        const resolveTheme = (preference) =>
          preference === 'system'
            ? media.matches
              ? 'dark'
              : 'light'
            : preference;

        const applyPreference = (preference, notify = true) => {
          const normalized = preferences.has(preference)
            ? preference
            : 'system';
          const resolved = resolveTheme(normalized);
          document.documentElement.classList.toggle(
            'dark',
            resolved === 'dark'
          );
          document.documentElement.dataset.themePreference = normalized;
          document.documentElement.dataset.themeResolved = resolved;

          const meta = document.getElementById('site-theme-color');
          if (meta)
            meta.setAttribute(
              'content',
              resolved === 'dark' ? '#071724' : '#f6f7f4'
            );

          if (notify) {
            window.dispatchEvent(
              new CustomEvent('ccus:themechange', {
                detail: { preference: normalized, resolved },
              })
            );
          }
          return resolved;
        };

        const setPreference = (preference) => {
          const normalized = preferences.has(preference)
            ? preference
            : 'system';
          window.localStorage.setItem(STORAGE_KEY, normalized);
          applyPreference(normalized);
        };

        window.__ccusThemeManager = {
          getPreference,
          resolveTheme,
          applyPreference,
          setPreference,
        };

        applyPreference(getPreference(), false);

        if (!window.__ccusThemeManagerBound) {
          media.addEventListener('change', () => {
            if (getPreference() === 'system') applyPreference('system');
          });
          document.addEventListener('astro:after-swap', () => {
            applyPreference(getPreference());
          });
          window.__ccusThemeManagerBound = true;
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css"
    />
  </head>
  <body
    class={`site-shell min-h-screen flex flex-col font-['Inter',_sans-serif] transition-colors ${pageClass}`.trim()}
  >
    <NavBar />
    <main class="site-main flex-grow">
      <slot />
    </main>
    {!hideCompareDrawer && <CompareDrawer lang={lang as 'zh' | 'en'} />}
    <Footer lang={lang as string} />

    <script is:inline>
      (() => {
        const configureRangeControls = () => {
          const minSlider = document.getElementById('minYearSlider');
          const maxSlider = document.getElementById('maxYearSlider');
          const isEnglish = document.documentElement.lang === 'en';

          minSlider?.setAttribute(
            'aria-label',
            isEnglish ? 'Minimum year in active range' : '有效时间范围起始年份'
          );
          maxSlider?.setAttribute(
            'aria-label',
            isEnglish ? 'Maximum year in active range' : '有效时间范围结束年份'
          );
        };

        if (!window.__ccusRangeLayerBound) {
          const activateRangeThumb = (target) => {
            if (!(target instanceof HTMLElement)) return;
            if (target.id !== 'minYearSlider' && target.id !== 'maxYearSlider')
              return;

            const root = target.closest('[data-capacity-trend]') || document;
            const minSlider = root.querySelector('#minYearSlider');
            const maxSlider = root.querySelector('#maxYearSlider');
            if (
              !(minSlider instanceof HTMLElement) ||
              !(maxSlider instanceof HTMLElement)
            )
              return;

            minSlider.style.zIndex = target === minSlider ? '34' : '31';
            maxSlider.style.zIndex = target === maxSlider ? '34' : '32';
          };

          document.addEventListener('pointerdown', (event) => {
            activateRangeThumb(event.target);
          });
          document.addEventListener('focusin', (event) => {
            activateRangeThumb(event.target);
          });
          document.addEventListener('astro:page-load', configureRangeControls);
          window.__ccusRangeLayerBound = true;
        }

        configureRangeControls();
      })();
    </script>
  </body>
</html>
