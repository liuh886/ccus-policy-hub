---
import { getCollection } from 'astro:content';

interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;
const isEn = lang === 'en';

const facilities = await getCollection(
  isEn ? 'facilities_en' : 'facilities_zh'
);

const hasRenderableCoordinates = (
  coordinates: unknown
): coordinates is [number, number] => {
  if (!Array.isArray(coordinates) || coordinates.length < 2) {
    return false;
  }

  const lat = Number(coordinates[0]);
  const lng = Number(coordinates[1]);

  if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
    return false;
  }

  // `0.001, 0.001` is used in the dataset as a placeholder for missing coordinates.
  return !(Math.abs(lat) < 0.01 && Math.abs(lng) < 0.01);
};

const countryPrecisionTotals = new Map<
  string,
  { lat: number; lng: number; count: number }
>();

for (const facility of facilities) {
  const { precision, country, coordinates } = facility.data;
  if (precision !== 'country' || !hasRenderableCoordinates(coordinates)) {
    continue;
  }

  const key = String(country || '');
  const current = countryPrecisionTotals.get(key) || {
    lat: 0,
    lng: 0,
    count: 0,
  };

  current.lat += coordinates[0];
  current.lng += coordinates[1];
  current.count += 1;
  countryPrecisionTotals.set(key, current);
}

const canonicalCountryCoordinates = new Map(
  [...countryPrecisionTotals.entries()].map(([country, totals]) => [
    country,
    [
      Number((totals.lat / totals.count).toFixed(4)),
      Number((totals.lng / totals.count).toFixed(4)),
    ] as [number, number],
  ])
);

const mapFacilities = facilities.map((facility) => {
  const { id, data } = facility;
  const isCountryPrecision = data.precision === 'country';
  const coordinates =
    isCountryPrecision && canonicalCountryCoordinates.has(String(data.country))
      ? canonicalCountryCoordinates.get(String(data.country))
      : hasRenderableCoordinates(data.coordinates)
        ? data.coordinates
        : null;

  return {
    id,
    name: data.name,
    coordinates,
    precision: data.precision,
    status: data.status,
    estimatedCapacity: data.estimatedCapacity,
    announcedCapacityMax: data.announcedCapacityMax,
    type: data.type,
  };
});

const mapData = { mapFacilities, isEn };
const mapDataJson = JSON.stringify(mapData);
---

<div
  class="facility-map-container h-[600px] w-full rounded-[2.5rem] overflow-hidden border border-slate-200 dark:border-slate-800 shadow-2xl relative bg-slate-100 dark:bg-slate-950"
>
  <div id="map" class="h-full w-full z-0"></div>

  <!-- Map Loader -->
  <div
    id="map-loader"
    class="absolute inset-0 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md z-[1000] flex flex-col items-center justify-center transition-opacity duration-700"
  >
    <div
      class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin"
    >
    </div>
  </div>

  <!-- Legend (Only) -->
  <div
    class="absolute bottom-6 right-6 z-[500] bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl p-5 rounded-3xl border border-slate-200/50 dark:border-slate-800/50 shadow-2xl"
  >
    <div class="space-y-3">
      <div
        class="flex items-center gap-3 text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2"
      >
        {isEn ? 'Legend' : '地图图例'}
      </div>
      <div class="flex items-center gap-3">
        <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
        <span class="text-[11px] font-bold text-slate-600 dark:text-slate-300"
          >{isEn ? 'Operational' : '运行中'}</span
        >
      </div>
      <div class="flex items-center gap-3">
        <div class="w-2.5 h-2.5 rounded-full bg-blue-500"></div>
        <span class="text-[11px] font-bold text-slate-600 dark:text-slate-300"
          >{isEn ? 'Planned' : '计划/开发中'}</span
        >
      </div>
    </div>
  </div>
</div>

<script
  is:inline
  type="application/json"
  id="facility-map-data"
  set:html={mapDataJson}
/>

<style is:global>
  .facility-map-marker {
    width: 14px;
    height: 14px;
    border: 2px solid #fff;
    border-radius: 9999px;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.3);
  }

  .facility-map-cluster {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 9999px;
    background: #0f172a;
    color: #fff;
    font-size: 10px;
    font-weight: 900;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.28);
  }

  .leaflet-div-icon.custom-marker,
  .leaflet-div-icon.custom-cluster-icon {
    background: transparent;
    border: 0;
  }
</style>

<script>
  // @ts-nocheck

  const escapeHtml = (value) =>
    String(value ?? '').replace(
      /[&<>"']/g,
      (char) =>
        ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;',
        })[char] || char
    );

  function getMapPayload() {
    const mapDataEl = document.getElementById('facility-map-data');
    const rawPayload = mapDataEl?.textContent?.trim() || '';

    if (!rawPayload) {
      return { mapFacilities: [], isEn: false };
    }

    const mapData = JSON.parse(rawPayload);

    return {
      mapFacilities: Array.isArray(mapData.mapFacilities)
        ? mapData.mapFacilities
        : [],
      isEn: Boolean(mapData.isEn),
    };
  }

  function hasRenderableCoordinates(coordinates) {
    if (!Array.isArray(coordinates) || coordinates.length < 2) {
      return false;
    }

    const lat = Number(coordinates[0]);
    const lng = Number(coordinates[1]);

    if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
      return false;
    }

    return !(Math.abs(lat) < 0.01 && Math.abs(lng) < 0.01);
  }

  async function initMap() {
    const mapShell = document.querySelector('.facility-map-container');
    const mapNode = document.getElementById('map');
    if (!mapShell || !mapNode || mapNode.dataset.mapReady === '1') return;

    if (mapNode._leaflet_id && !mapNode.dataset.mapReady) {
      delete mapNode._leaflet_id;
      mapNode.innerHTML = '';
    }

    const { mapFacilities, isEn } = getMapPayload();

    try {
      const leafletModule = await import('leaflet');
      const L = leafletModule.default;
      window.L = L;

      try {
        await import('leaflet.markercluster');
      } catch (pluginError) {
        console.warn(
          'Leaflet markercluster failed to load; falling back to plain markers.',
          pluginError
        );
      }

      const map = L.map(mapNode, {
        center: [30, 10],
        zoom: 3,
        zoomControl: false,
        attributionControl: false,
        preferCanvas: true,
      });

      L.control.zoom({ position: 'topleft' }).addTo(map);

      const isDark = document.documentElement.classList.contains('dark');
      const esriUrl = isDark
        ? 'https://services.arcgisonline.com/ArcGIS/rest/services/Canvas/World_Dark_Gray_Base/MapServer/tile/{z}/{y}/{x}'
        : 'https://services.arcgisonline.com/ArcGIS/rest/services/Canvas/World_Light_Gray_Base/MapServer/tile/{z}/{y}/{x}';

      L.tileLayer(esriUrl, { maxZoom: 16, minZoom: 2 }).addTo(map);

      const markers =
        typeof L.markerClusterGroup === 'function'
          ? L.markerClusterGroup({
              showCoverageOnHover: false,
              maxClusterRadius: 40,
              spiderfyOnMaxZoom: true,
              chunkedLoading: true,
              chunkDelay: 40,
              chunkInterval: 200,
              iconCreateFunction: (cluster) =>
                L.divIcon({
                  html: `<div class="facility-map-cluster">${cluster.getChildCount()}</div>`,
                  className: 'custom-cluster-icon',
                  iconSize: [32, 32],
                  iconAnchor: [16, 16],
                }),
            })
          : L.layerGroup();

      const markerBounds = [];

      mapFacilities.forEach((f) => {
        const {
          name,
          coordinates,
          precision,
          status,
          estimatedCapacity,
          announcedCapacityMax,
          type,
        } = f;
        if (!hasRenderableCoordinates(coordinates)) return;
        const isOperational = status === '运行中' || status === 'Operational';
        const color = isOperational ? '#10b981' : '#3b82f6';
        const opacity = precision === 'exact' ? 1.0 : precision === 'state' ? 0.7 : 0.4;
        const lat = Number(coordinates[0]);
        const lng = Number(coordinates[1]);
        const latLng = [lat, lng];

        const displayCap = estimatedCapacity || announcedCapacityMax || 0;
        const safeName = escapeHtml(name);
        const safeType = escapeHtml(type);
        const safeStatus = escapeHtml(status);
        const safeId = encodeURIComponent(String(f.id));

        const safePrecision = escapeHtml(precision);
        const precisionLabel = isEn ? `Precision: ${safePrecision}` : `定位精度: ${safePrecision === 'exact' ? '精确' : safePrecision === 'state' ? '省级/区域' : '国家级'}`;

        const marker = L.marker(latLng, {
          icon: L.divIcon({
            html: `<div class="facility-map-marker" style="background-color: ${color}; opacity: ${opacity}; border: ${precision === 'exact' ? '2.5px' : '1.5px'} solid #fff;"></div>`,
            className: 'custom-marker',
            iconSize: [14, 14],
            iconAnchor: [7, 7],
          }),
        });

        marker.bindPopup(`
        <div class="p-1 min-w-[180px]">
          <div class="flex justify-between items-start mb-1">
            <div class="text-[9px] font-black text-blue-600 uppercase">${safeType}</div>
            <div class="text-[8px] font-bold text-slate-400 bg-slate-100 dark:bg-slate-800 px-1 rounded">${precisionLabel}</div>
          </div>
          <div class="text-sm font-black text-slate-900 dark:text-white mb-2">${safeName}</div>
          <div class="text-xs font-bold text-slate-500">${displayCap} Mtpa | ${safeStatus}</div>
          <a href="/ccus-policy-hub/${isEn ? 'en/facilities' : 'facilities'}/${safeId}/" class="block mt-3 text-center py-1.5 bg-slate-900 text-white text-[9px] font-black uppercase rounded-lg transition-transform hover:scale-[1.02]">Details</a>
        </div>
      `);
        markers.addLayer(marker);
        markerBounds.push(latLng);
      });

      map.addLayer(markers);
      requestAnimationFrame(() => {
        map.invalidateSize();
        if (markerBounds.length > 0) {
          map.fitBounds(markerBounds, {
            padding: [32, 32],
            maxZoom: 6,
          });
        }
      });
      const loader = document.getElementById('map-loader');
      if (loader) {
        loader.style.opacity = '0';
        setTimeout(() => (loader.style.display = 'none'), 500);
      }
      mapNode.dataset.mapReady = '1';
    } catch (error) {
      mapNode.dataset.mapReady = '';
      throw error;
    }
  }

  function setupMap() {
    const mapShell = document.querySelector('.facility-map-container');
    if (!mapShell || mapShell.getAttribute('data-map-observed') === '1') {
      return;
    }

    mapShell.setAttribute('data-map-observed', '1');

    const start = () => {
      void initMap();
    };

    if (!('IntersectionObserver' in window)) {
      start();
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          observer.disconnect();
          start();
        }
      },
      { rootMargin: '200px 0px' }
    );

    observer.observe(mapShell);
  }

  document.addEventListener('astro:page-load', setupMap);
  setupMap();
</script>
