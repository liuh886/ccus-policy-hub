{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://liuh886.github.io/ccus-policy-hub/data/schemas/manifest.schema.json",
  "title": "CCUS Policy Hub Data Manifest",
  "description": "Manifest describing available data endpoints and schemas",
  "type": "object",
  "required": ["generated_at", "project", "datasets"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the manifest was generated"
    },
    "project": {
      "type": "string",
      "description": "Project name"
    },
    "description": {
      "type": "string",
      "description": "Project description"
    },
    "version": {
      "type": "string",
      "description": "Data format version"
    },
    "source_db": {
      "type": "string",
      "description": "Path to source SQLite database"
    },
    "datasets": {
      "type": "object",
      "description": "Available dataset endpoints",
      "additionalProperties": {
        "type": "object",
        "required": ["file", "description"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Path to the JSON file"
          },
          "count": {
            "type": "integer",
            "description": "Number of records in the dataset"
          },
          "description": {
            "type": "string",
            "description": "Description of the dataset"
          }
        }
      }
    },
    "schemas": {
      "type": "object",
      "description": "JSON Schema definitions",
      "additionalProperties": {
        "type": "string",
        "description": "Path to the schema file"
      }
    },
    "documentation": {
      "type": "object",
      "description": "Documentation files",
      "properties": {
        "llms": {
          "type": "string",
          "description": "Path to llms.txt"
        },
        "llms-full": {
          "type": "string",
          "description": "Path to llms-full.txt"
        }
      }
    },
    "known_limitations": {
      "type": "array",
      "description": "Known limitations of the data",
      "items": {
        "type": "string"
      }
    }
  }
}
