---
import { getCollection } from 'astro:content';
import {
  facilityCapacity,
  normalizeFacilityStatus,
  normalizeFacilityType,
  summarizeFacilities,
} from '../lib/capacityMetrics.mjs';

const lang = Astro.currentLocale || 'zh';
const facilities = await getCollection(
  lang === 'en' ? 'facilities_en' : 'facilities_zh'
);
type Facility = (typeof facilities)[number];

const startYear = 1970;
const endYear = 2040;
const defaultMinYear = 1990;
const defaultMaxYear = 2030;
const pipelineStatuses = new Set([
  'planned',
  'operational',
  'under-construction',
]);
const committedStatuses = new Set(['operational', 'under-construction']);
const typeOptions = [
  { id: 'capture', label: 'Capture' },
  { id: 'transport', label: 'Transport' },
  { id: 'ts', label: 'T&S' },
  { id: 'storage', label: 'Storage' },
  { id: 'full-chain', label: 'Full chain' },
  { id: 'ccu', label: 'CCU' },
] as const;

type TypeId = (typeof typeOptions)[number]['id'];
type ChartPoint = {
  year: number;
  operational: number;
  pipeline: number;
};
type CapacityRecord = {
  year: number;
  typeId: TypeId | null;
  capacity: number;
  committed: boolean;
  pipeline: boolean;
};

const text = {
  totalTitle: lang === 'zh' ? '全球项目记录能力' : 'Global Project-Record Capacity',
  totalYearSuffix: lang === 'zh' ? '估' : ' Est.',
  totalNote:
    lang === 'zh'
      ? 'Planned、Operational 与 Under construction 项目记录能力累计；排除 Cancelled / Decommissioned / Suspended。'
      : 'Cumulative project-record capacity for Planned, Operational and Under construction records; Cancelled / Decommissioned / Suspended excluded.',
  chartTitle:
    lang === 'zh'
      ? '全球 CCUS 项目记录能力增长趋势'
      : 'CCUS Project-Record Capacity Growth',
  committedLabel:
    lang === 'zh'
      ? '确定性能力（在运+在建）'
      : 'Committed (Operational + Under construction)',
  pipelineLabel:
    lang === 'zh'
      ? '公开管线（规划+在运+在建）'
      : 'Pipeline (Planned + Operational + Under construction)',
  typeFilterTitle: lang === 'zh' ? '类型' : 'Types',
  operationalTitle:
    lang === 'zh'
      ? '在运设施（项目记录规模）'
      : 'Operational facilities (project-record scale)',
  constructionTitle:
    lang === 'zh'
      ? '在建设施（项目记录规模）'
      : 'Under-construction facilities (project-record scale)',
  storageSubsetLabel:
    lang === 'zh' ? '其中封存相关' : 'Storage-related subset',
  storageSubsetNote:
    lang === 'zh'
      ? '封存相关包括 T&S、Storage 与 Full chain 项目记录；不等于净可交付地质封存能力。'
      : 'Storage-related includes T&S, Storage and Full chain project records; it is not net deliverable geological storage capacity.',
  chartNote:
    lang === 'zh'
      ? '注：本图采用 project-record 口径，按 operation → FID → announcement 年份累计 Planned、Operational、Under construction 项目记录能力；Cancelled、Decommissioned、Suspended 被排除。筛选项覆盖 capture、transport、T&S、storage、full-chain、CCU。数值为跨类型项目记录能力加总，不代表净可交付捕集能力或净封存能力。'
      : 'Note: This chart uses a project-record methodology, accumulating Planned, Operational and Under construction records by operation → FID → announcement year; Cancelled, Decommissioned and Suspended records are excluded. The type filter covers capture, transport, T&S, storage, full-chain and CCU. Values aggregate project-record capacity across selected types and should not be interpreted as net deliverable capture or storage capacity.',
};

const parseYear = (value: unknown): number | null => {
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  if (typeof value !== 'string') return null;
  const match = value.match(/\d{4}/);
  return match ? Number.parseInt(match[0], 10) : null;
};

const projectRecordYear = (facility: Facility): number | null =>
  parseYear(facility.data.operation) ??
  parseYear(facility.data.fid) ??
  parseYear(facility.data.announcement);

const trendYears = Array.from(
  { length: endYear - startYear + 1 },
  (_, index) => startYear + index
);

const capacityRecords: CapacityRecord[] = facilities.flatMap((facility) => {
  const year = projectRecordYear(facility);
  const status = normalizeFacilityStatus(facility.data.status);

  if (!year || year < startYear || year > endYear || !pipelineStatuses.has(status)) {
    return [];
  }

  return [
    {
      year,
      typeId: normalizeFacilityType(facility.data.type) as TypeId | null,
      capacity: facilityCapacity(facility.data),
      committed: committedStatuses.has(status),
      pipeline: true,
    },
  ];
});

const buildSeries = (records: CapacityRecord[]): ChartPoint[] => {
  let cumulativeCommitted = 0;
  let cumulativePipeline = 0;

  return trendYears.map((year) => {
    records.forEach((record) => {
      if (record.year !== year) return;
      if (record.committed) cumulativeCommitted += record.capacity;
      if (record.pipeline) cumulativePipeline += record.capacity;
    });

    return {
      year,
      operational: cumulativeCommitted,
      pipeline: cumulativePipeline,
    };
  });
};

const chartData = buildSeries(capacityRecords);
const typeChartData: Record<string, ChartPoint[]> = {};
typeOptions.forEach((option) => {
  typeChartData[option.id] = buildSeries(
    capacityRecords.filter((record) => record.typeId === option.id)
  );
});

const capacityAtYear = (series: ChartPoint[], year: number): number =>
  series.find((point) => point.year === year)?.pipeline || 0;

const totalCapacity = capacityAtYear(chartData, defaultMaxYear).toFixed(1);
const operationalSummary = summarizeFacilities(facilities, 'operational');
const constructionSummary = summarizeFacilities(facilities, 'under-construction');

const formatCapacity = (value: number): string => value.toFixed(1);
const metricOpen = lang === 'zh' ? '（' : '(';
const metricClose = lang === 'zh' ? '）' : ')';
---

<div data-capacity-trend class="mb-16 grid grid-cols-1 gap-8 lg:grid-cols-3">
  <div class="space-y-6 lg:col-span-1">
    <section
      class="group relative overflow-hidden rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition-all duration-500 hover:border-emerald-500/50 dark:border-slate-800 dark:bg-slate-900"
    >
      <div
        class="absolute left-0 top-0 h-full w-1.5 bg-emerald-500/0 transition-all group-hover:bg-emerald-500/50"
      ></div>
      <div
        class="absolute right-4 top-2 font-mono text-[8px] text-slate-300 dark:text-slate-700"
      >
        CAP_MONITOR_v3.5
      </div>
      <h3 class="mb-4 text-xs font-black uppercase tracking-widest text-slate-400">
        {text.totalTitle}
        <span data-capacity-total-year>({defaultMaxYear}{text.totalYearSuffix})</span>
      </h3>
      <div class="mb-2 text-5xl font-black tracking-tighter text-emerald-600">
        <span data-capacity-total>{totalCapacity}</span>
        <span class="text-sm font-bold uppercase text-slate-400">Mtpa</span>
      </div>
      <p class="text-xs font-medium text-slate-500">{text.totalNote}</p>
    </section>

    <section
      class="relative overflow-hidden rounded-3xl border border-slate-800 bg-slate-900 p-8 text-white shadow-2xl"
      aria-describedby="storage-related-method-note"
    >
      <div class="space-y-5">
        <div>
          <h3 class="mb-2 text-[11px] font-black uppercase tracking-widest text-blue-300">
            {text.operationalTitle}
          </h3>
          <p class="text-3xl font-black tracking-tight text-white">
            {operationalSummary.totalCount}{lang === 'zh' ? '个' : ''}
            <span class="text-lg font-bold text-blue-300">
              {metricOpen}{formatCapacity(operationalSummary.totalCapacity)} Mtpa{metricClose}
            </span>
          </p>
          <p class="mt-2 text-sm font-semibold text-emerald-300">
            {text.storageSubsetLabel}
            {operationalSummary.storageRelatedCount}{lang === 'zh' ? '个' : ''}
            {metricOpen}{formatCapacity(operationalSummary.storageRelatedCapacity)} Mtpa{metricClose}
          </p>
        </div>

        <div class="border-t border-white/10 pt-5">
          <h3 class="mb-2 text-[11px] font-black uppercase tracking-widest text-emerald-300">
            {text.constructionTitle}
          </h3>
          <p class="text-3xl font-black tracking-tight text-white">
            {constructionSummary.totalCount}{lang === 'zh' ? '个' : ''}
            <span class="text-lg font-bold text-emerald-300">
              {metricOpen}{formatCapacity(constructionSummary.totalCapacity)} Mtpa{metricClose}
            </span>
          </p>
          <p class="mt-2 text-sm font-semibold text-emerald-300">
            {text.storageSubsetLabel}
            {constructionSummary.storageRelatedCount}{lang === 'zh' ? '个' : ''}
            {metricOpen}{formatCapacity(constructionSummary.storageRelatedCapacity)} Mtpa{metricClose}
          </p>
        </div>
      </div>

      <p
        id="storage-related-method-note"
        class="mt-5 border-t border-white/10 pt-4 text-[10px] leading-relaxed text-slate-400"
      >
        {text.storageSubsetNote}
      </p>
    </section>
  </div>

  <section
    class="group/chart relative overflow-hidden rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition-all duration-500 hover:border-blue-500/30 dark:border-slate-800 dark:bg-slate-900 lg:col-span-2"
  >
    <div class="relative z-10 mb-4 flex items-start justify-between gap-4">
      <div>
        <h3 class="mb-1 text-lg font-black uppercase tracking-tight dark:text-white">
          {text.chartTitle}
        </h3>
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400">
          Project-record capacity across selected CCUS types (Mtpa)
          <span class="text-blue-500">1970</span> -
          <span class="text-emerald-500" data-capacity-subtitle-max>{defaultMaxYear}</span>
        </p>
      </div>
      <div
        class="rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-[10px] font-black uppercase tracking-widest text-blue-700 shadow-sm dark:border-blue-500/20 dark:bg-blue-500/10 dark:text-blue-400"
      >
        IEA 2026 Intelligence
      </div>
    </div>

    <div class="relative z-10 mb-6 mt-2 flex flex-col gap-3 px-2">
      <div class="flex items-center justify-between gap-4">
        <div
          id="timeRangeIndicator"
          class="rounded-full border border-blue-500/20 bg-blue-500/10 px-3 py-1 font-mono text-[10px] text-blue-600 dark:text-blue-400"
        >
          <span class="opacity-40">[</span>
          <span id="yearMinVal" class="font-bold">{defaultMinYear}</span> -
          <span id="yearMaxVal" class="font-bold">{defaultMaxYear}</span>
          <span class="opacity-40">]</span>
          <span class="ml-1.5 text-[9px] font-black tracking-tighter text-emerald-500">
            {lang === 'zh' ? '视图激活' : 'ACTIVE_VIEW'}
          </span>
        </div>
        <div class="text-[9px] font-black uppercase tracking-[0.2em] text-slate-400">
          Timeline viewport
        </div>
      </div>

      <div class="group/slider relative flex h-7 w-full items-center">
        <div class="absolute h-1 w-full rounded-full bg-slate-100 shadow-inner dark:bg-slate-800/50"></div>
        <div id="sliderTrackHighlight" class="absolute z-10 rounded-full"></div>
        <input
          type="range"
          id="minYearSlider"
          min={startYear}
          max={endYear}
          value={defaultMinYear}
          aria-label={lang === 'zh' ? '起始年份' : 'Start year'}
        />
        <input
          type="range"
          id="maxYearSlider"
          min={startYear}
          max={endYear}
          value={defaultMaxYear}
          aria-label={lang === 'zh' ? '结束年份' : 'End year'}
        />
      </div>
    </div>

    <div class="relative z-10 grid grid-cols-1 gap-4 md:grid-cols-[100px_1fr]">
      <aside
        id="capacityTypeFilter"
        class="rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3 dark:border-slate-800 dark:bg-slate-950/30"
      >
        <div class="mb-2 text-[9px] font-black uppercase tracking-widest text-slate-500 dark:text-slate-400">
          {text.typeFilterTitle}
        </div>
        <div class="space-y-1.5">
          {
            typeOptions.map((option) => (
              <label
                for={`capacity-type-${option.id}`}
                class="flex cursor-pointer select-none items-center gap-1.5 text-[10px] font-bold text-slate-600 dark:text-slate-300"
              >
                <input
                  id={`capacity-type-${option.id}`}
                  type="checkbox"
                  value={option.id}
                  checked
                  data-capacity-type
                  class="h-3 w-3 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                />
                <span>{option.label}</span>
              </label>
            ))
          }
        </div>
      </aside>

      <div class="relative h-[300px] w-full">
        <canvas
          id="capacityChart"
          data-values={JSON.stringify(chartData)}
          data-type-series={JSON.stringify(typeChartData)}
          data-label-op={text.committedLabel}
          data-label-pipe={text.pipelineLabel}
          data-default-min-year={defaultMinYear}
          data-default-max-year={defaultMaxYear}
          data-start-year={startYear}
          data-end-year={endYear}
          data-year-suffix={text.totalYearSuffix}
        ></canvas>
      </div>
    </div>

    <p class="relative z-10 mt-4 text-[10px] leading-relaxed text-slate-500 dark:text-slate-400">
      {text.chartNote}
    </p>
  </section>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script is:inline>
  function initCapacityChart() {
    const canvas = document.getElementById('capacityChart');
    if (!canvas || typeof Chart === 'undefined') return;

    const root = canvas.closest('[data-capacity-trend]') || document;
    const minSlider = root.querySelector('#minYearSlider');
    const maxSlider = root.querySelector('#maxYearSlider');
    const trackHighlight = root.querySelector('#sliderTrackHighlight');
    const yearMinVal = root.querySelector('#yearMinVal');
    const yearMaxVal = root.querySelector('#yearMaxVal');
    const subtitleMaxYear = root.querySelector('[data-capacity-subtitle-max]');
    const totalValue = root.querySelector('[data-capacity-total]');
    const totalYear = root.querySelector('[data-capacity-total-year]');
    const typeCheckboxes = Array.from(root.querySelectorAll('[data-capacity-type]'));

    const existingChart = Chart.getChart(canvas);
    if (existingChart) existingChart.destroy();

    try {
      const allSeries = JSON.parse(canvas.dataset.values || '[]');
      const typeSeries = JSON.parse(canvas.dataset.typeSeries || '{}');
      if (allSeries.length === 0) return;

      const labels = allSeries.map((point) => point.year);
      const defaultMinYear = Number(canvas.dataset.defaultMinYear || 1990);
      const defaultMaxYear = Number(canvas.dataset.defaultMaxYear || 2030);
      const startYear = Number(canvas.dataset.startYear || 1970);
      const endYear = Number(canvas.dataset.endYear || 2040);
      const yearSuffix = canvas.dataset.yearSuffix || ' Est.';

      const zeroSeries = () => ({
        operational: labels.map(() => 0),
        pipeline: labels.map(() => 0),
      });

      const selectedTypeIds = () =>
        typeCheckboxes
          .filter((checkbox) => checkbox.checked)
          .map((checkbox) => checkbox.value);

      const combineSelectedSeries = () => {
        const selectedTypes = selectedTypeIds();
        if (selectedTypes.length === typeCheckboxes.length) {
          return {
            operational: allSeries.map((point) => Number(point.operational || 0)),
            pipeline: allSeries.map((point) => Number(point.pipeline || 0)),
          };
        }

        return selectedTypes.reduce((series, typeId) => {
          const points = typeSeries[typeId] || [];
          points.forEach((point, index) => {
            series.operational[index] += Number(point.operational || 0);
            series.pipeline[index] += Number(point.pipeline || 0);
          });
          return series;
        }, zeroSeries());
      };

      const yearIndex = (year) => {
        const index = labels.findIndex((label) => Number(label) === Number(year));
        return index >= 0 ? index : labels.length - 1;
      };

      const currentMaxYear = () =>
        maxSlider ? Number.parseInt(maxSlider.value, 10) : defaultMaxYear;

      const updateTotalDisplay = (series, maxYear) => {
        const activeYear = maxYear || currentMaxYear();
        const activePipeline = series.pipeline[yearIndex(activeYear)] || 0;

        if (totalValue) totalValue.textContent = Number(activePipeline).toFixed(1);
        if (totalYear) totalYear.textContent = `(${activeYear}${yearSuffix})`;
        if (subtitleMaxYear) subtitleMaxYear.textContent = activeYear;
      };

      const initialSeries = combineSelectedSeries();
      const chart = new Chart(canvas, {
        type: 'line',
        data: {
          labels,
          datasets: [
            {
              label: canvas.dataset.labelOp,
              data: initialSeries.operational,
              borderColor: '#2563eb',
              backgroundColor: 'rgba(37, 99, 235, 0.1)',
              fill: true,
              tension: 0.3,
              borderWidth: 4,
              pointRadius: 0,
              pointHoverRadius: 6,
              spanGaps: false,
            },
            {
              label: canvas.dataset.labelPipe,
              data: initialSeries.pipeline,
              borderColor: '#10b981',
              backgroundColor: 'rgba(16, 185, 129, 0.05)',
              fill: true,
              tension: 0.3,
              borderWidth: 4,
              pointRadius: 0,
              pointHoverRadius: 6,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              display: true,
              position: 'top',
              align: 'end',
              labels: { boxWidth: 12, usePointStyle: true, font: { size: 10 } },
            },
            tooltip: {
              padding: 10,
              backgroundColor: '#0f172a',
              callbacks: {
                label(context) {
                  const value = Number(context.parsed.y || 0).toFixed(1);
                  return `${context.dataset.label}: ${value} Mtpa`;
                },
              },
            },
          },
          scales: {
            x: {
              min: defaultMinYear,
              max: defaultMaxYear,
              grid: { display: false },
              ticks: { font: { size: 10 }, color: '#94a3b8', maxTicksLimit: 10 },
            },
            y: {
              beginAtZero: true,
              grid: { color: 'rgba(148, 163, 184, 0.1)' },
              ticks: {
                font: { size: 10 },
                color: '#94a3b8',
                callback(value) {
                  return Number(value).toFixed(0);
                },
              },
            },
          },
        },
      });

      const updateFilteredSeries = () => {
        const nextSeries = combineSelectedSeries();
        chart.data.datasets[0].data = nextSeries.operational;
        chart.data.datasets[1].data = nextSeries.pipeline;
        updateTotalDisplay(nextSeries);
        chart.update();
      };

      const updateSliderUI = (event) => {
        if (!minSlider || !maxSlider) return;

        let min = Number.parseInt(minSlider.value, 10);
        let max = Number.parseInt(maxSlider.value, 10);

        if (min >= max) {
          if (event?.target === minSlider) {
            min = max - 1;
            minSlider.value = String(min);
          } else {
            max = min + 1;
            maxSlider.value = String(max);
          }
        }

        const minPercent = ((min - startYear) / (endYear - startYear)) * 100;
        const maxPercent = ((max - startYear) / (endYear - startYear)) * 100;

        if (trackHighlight) {
          trackHighlight.style.left = `${minPercent}%`;
          trackHighlight.style.width = `${maxPercent - minPercent}%`;
        }

        if (yearMinVal) yearMinVal.textContent = String(min);
        if (yearMaxVal) yearMaxVal.textContent = String(max);

        minSlider.style.zIndex = event?.target === minSlider ? '34' : '31';
        maxSlider.style.zIndex = event?.target === maxSlider ? '34' : '32';

        chart.options.scales.x.min = min;
        chart.options.scales.x.max = max;
        updateTotalDisplay(combineSelectedSeries(), max);
        chart.update('none');
      };

      typeCheckboxes.forEach((checkbox) => {
        checkbox.addEventListener('change', updateFilteredSeries);
      });

      if (minSlider && maxSlider) {
        minSlider.addEventListener('input', updateSliderUI);
        maxSlider.addEventListener('input', updateSliderUI);
        minSlider.addEventListener('focus', updateSliderUI);
        maxSlider.addEventListener('focus', updateSliderUI);
        updateSliderUI();
      } else {
        updateTotalDisplay(initialSeries, defaultMaxYear);
      }
    } catch (error) {
      console.error('Failed to init capacity chart:', error);
    }
  }

  document.addEventListener('astro:page-load', initCapacityChart);
  if (document.readyState === 'complete') {
    initCapacityChart();
  } else {
    window.addEventListener('load', initCapacityChart);
  }
</script>
