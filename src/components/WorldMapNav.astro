---
import { ui, defaultLang } from '../i18n/ui';
const lang = Astro.props.lang || defaultLang;
const isEn = lang === 'en';
const t = (key: keyof (typeof ui)['zh']) =>
  ui[lang as keyof typeof ui][key] || ui[defaultLang][key];

interface Policy {
  name: string;
  enName: string;
  weight: number;
  x: number; // relative x offset from region center
  y: number; // relative y offset from region center
}

interface Region {
  id: string;
  name: string;
  enName: string;
  x: number; // percentage from left
  y: number; // percentage from top
  policies: Policy[];
  href: string;
  enHref: string;
}

const BASE = '/ccus-policy-hub';

const regions: Region[] = [
  {
    id: 'north-america',
    name: '北美',
    enName: 'North America',
    x: 22,
    y: 38,
    policies: [
      { name: '45Q 抵免', enName: '45Q Credit', weight: 1.8, x: -35, y: -40 },
      { name: 'IRA 法案', enName: 'IRA Act', weight: 1.6, x: 50, y: -20 },
      { name: 'EPA Class VI', enName: 'EPA Class VI', weight: 1.5, x: -75, y: -15 },
      { name: '税收抵免', enName: 'Tax Credit', weight: 1.4, x: 45, y: 35 },
      { name: 'EPA 准则', enName: 'EPA Rules', weight: 1.2, x: 30, y: 55 },
      { name: '低碳燃料标准', enName: 'LCFS', weight: 1.1, x: -55, y: 20 },
      { name: 'Alberta TIER', enName: 'Alberta TIER', weight: 1.2, x: -25, y: 60 },
      { name: 'Clean Fuel Regs', enName: 'Clean Fuel Regs', weight: 1.1, x: 75, y: 15 },
    ],
    href: `${BASE}/policy/us-45q-ira/`,
    enHref: `${BASE}/en/policy/us-45q-ira/`,
  },
  {
    id: 'europe',
    name: '欧洲',
    enName: 'Europe',
    x: 48,
    y: 32,
    policies: [
      { name: 'NZIA 净零', enName: 'NZIA', weight: 1.8, x: 5, y: -50 },
      { name: '创新基金', enName: 'Innovation Fund', weight: 1.7, x: -80, y: -25 },
      { name: 'EU ETS', enName: 'EU ETS', weight: 1.5, x: 65, y: -10 },
      { name: 'CRCF', enName: 'CRCF', weight: 1.4, x: -45, y: 25 },
      { name: '存储强制目标', enName: 'Storage Mandate', weight: 1.3, x: -85, y: 10 },
      { name: 'CBAM 碳关税', enName: 'CBAM', weight: 1.2, x: 35, y: 45 },
      { name: 'ETS MRR', enName: 'ETS MRR', weight: 1.3, x: 70, y: 20 },
      { name: 'Horizon Europe', enName: 'Horizon Europe', weight: 1.1, x: -10, y: 65 },
    ],
    href: `${BASE}/policy/eu-nzia/`,
    enHref: `${BASE}/en/policy/eu-nzia/`,
  },
  {
    id: 'china',
    name: '中国',
    enName: 'China',
    x: 74,
    y: 42,
    policies: [
      { name: '碳减排支持工具', enName: 'CERF', weight: 1.8, x: -20, y: -50 },
      { name: '工业规划', enName: 'Industrial Plan', weight: 1.6, x: 75, y: -30 },
      { name: 'CCER 重启', enName: 'CCER Restart', weight: 1.5, x: 60, y: -10 },
      { name: '标准体系', enName: 'Standards', weight: 1.4, x: -75, y: -20 },
      { name: '绿色金融', enName: 'Green Finance', weight: 1.3, x: 20, y: 45 },
      { name: '示范项目', enName: 'Demo Projects', weight: 1.2, x: -55, y: 40 },
      { name: 'VVB 核查', enName: 'VVB Verify', weight: 1.1, x: -85, y: 15 },
      { name: '碳普惠', enName: 'Carbon Inclusive', weight: 1.1, x: -35, y: 65 },
    ],
    href: `${BASE}/policy/cn-pboc-cerf/`,
    enHref: `${BASE}/en/policy/cn-pboc-cerf/`,
  },
  {
    id: 'sea',
    name: '东南亚',
    enName: 'SEA',
    x: 78,
    y: 68,
    policies: [
      { name: '第14/2024号总统条例', enName: 'Presidential Reg 14', weight: 1.7, x: 5, y: -45 },
      { name: 'CCS Hub', enName: 'CCS Hub', weight: 1.5, x: -70, y: -20 },
      { name: '碳税体系', enName: 'Carbon Tax', weight: 1.4, x: 65, y: 20 },
      { name: '税收优惠', enName: 'Tax Incentive', weight: 1.3, x: 20, y: 50 },
      { name: '跨境监管', enName: 'Cross-border', weight: 1.2, x: -55, y: 35 },
      { name: 'Article 6.4', enName: 'Article 6.4', weight: 1.2, x: -10, y: 60 },
    ],
    href: `${BASE}/policy/id-presidential-reg-14-2024/`,
    enHref: `${BASE}/en/policy/id-presidential-reg-14-2024/`,
  },
  {
    id: 'global',
    name: '全球趋势',
    enName: 'Global Trends',
    x: 50,
    y: 75,
    policies: [
      { name: 'Article 6', enName: 'Article 6', weight: 1.6, x: -75, y: -50 },
      { name: 'SBTi 净零标准', enName: 'SBTi Net-Zero', weight: 1.5, x: -45, y: -25 },
      { name: 'CDR', enName: 'CDR', weight: 1.4, x: 65, y: -20 },
      { name: 'DAC 移除', enName: 'DAC Removal', weight: 1.3, x: 45, y: -45 },
      { name: '蓝氢', enName: 'Blue Hydrogen', weight: 1.2, x: 60, y: 30 },
      { name: 'BECCS', enName: 'BECCS', weight: 1.1, x: 5, y: 45 },
    ],
    href: `${BASE}/policy/`,
    enHref: `${BASE}/en/policy/`,
  },
];
---

<div
  class="relative w-full aspect-[2.4/1] bg-slate-950 rounded-[3rem] border border-slate-800 p-8 overflow-hidden shadow-[0_0_50px_rgba(0,0,0,0.5)] group/console"
>
  <!-- High-Tech Intelligence Header -->
  <div class="absolute top-10 left-12 z-30 pointer-events-none">
    <div class="flex items-center gap-4 mb-3">
      <div class="relative flex h-3 w-3">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-cyan-500"></span>
      </div>
      <div class="h-[1px] w-16 bg-gradient-to-r from-cyan-500/50 to-transparent"></div>
      <div class="text-cyan-400 text-[11px] font-black uppercase tracking-[0.3em] font-mono">
        {t('home.console.subtitle')}
      </div>
    </div>
    <h3 class="text-3xl font-black text-white tracking-tighter mb-1">
      {t('home.console.title')}
    </h3>
    <div class="text-slate-500 text-xs font-medium max-w-xs leading-relaxed">
      {t('home.console.description')}
    </div>
  </div>

  <!-- Digital Background Grid -->
  <div class="absolute inset-0 pointer-events-none z-0">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#334155 1px, transparent 1px), linear-gradient(90deg, #334155 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(#3b82f6 1px, transparent 1px); background-size: 20px 20px;"></div>
  </div>

  <!-- Abstract World Map (SVG Background) -->
  <div class="absolute inset-0 z-10 opacity-20 group-hover/console:opacity-40 transition-opacity duration-1000 flex items-center justify-center">
    <svg viewBox="0 0 1000 500" class="w-full h-full scale-110">
      <defs>
        <pattern id="dotPattern" x="0" y="0" width="12" height="12" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1.2" fill="#334155" />
        </pattern>
      </defs>
      
      <!-- Simplified Continent Shapes -->
      <g class="continents">
        <!-- N. America -->
        <path d="M100,100 L250,80 L320,150 L300,300 L150,350 L80,250 Z" fill="url(#dotPattern)" stroke="#1e293b" stroke-width="0.5" />
        <!-- S. America -->
        <path d="M280,320 L350,330 L380,450 L300,480 L250,420 Z" fill="url(#dotPattern)" stroke="#1e293b" stroke-width="0.5" />
        <!-- Europe & Africa -->
        <path d="M450,100 L550,80 L600,150 L580,250 L480,300 L420,250 Z" fill="url(#dotPattern)" stroke="#1e293b" stroke-width="0.5" />
        <path d="M480,310 L580,320 L620,450 L500,480 L440,400 Z" fill="url(#dotPattern)" stroke="#1e293b" stroke-width="0.5" />
        <!-- Asia & Oceania -->
        <path d="M620,100 L850,80 L950,200 L900,350 L750,380 L650,300 Z" fill="url(#dotPattern)" stroke="#1e293b" stroke-width="0.5" />
        <path d="M800,400 L900,410 L920,480 L820,470 Z" fill="url(#dotPattern)" stroke="#1e293b" stroke-width="0.5" />
      </g>
    </svg>
  </div>

  <!-- Interactive Region Layer -->
  <div class="absolute inset-0 z-20 flex items-center justify-center pointer-events-none">
    <div class="relative w-full h-full">
      {
        regions.map((r) => (
          <div
            class="absolute pointer-events-auto"
            style={`left: ${r.x}%; top: ${r.y}%;`}
          >
            <a href={isEn ? r.enHref : r.href} class="relative block group/node">
              <!-- Hub Visuals -->
              <div class="absolute -inset-10 bg-cyan-500/0 group-hover/node:bg-cyan-500/5 rounded-full transition-all duration-700 blur-2xl"></div>
              
              <div class="relative flex items-center justify-center">
                <div class="absolute w-4 h-4 bg-cyan-500/30 rounded-full animate-ping"></div>
                <div class="absolute w-2.5 h-2.5 bg-cyan-400 rounded-full shadow-[0_0_15px_rgba(34,211,238,0.8)] z-10"></div>
                
                <!-- Label (Visible on Hover) -->
                <div class="absolute top-6 left-6 whitespace-nowrap opacity-0 group-hover/node:opacity-100 transition-all duration-500 transform translate-y-2 group-hover/node:translate-y-0 z-30">
                   <div class="px-3 py-1.5 bg-slate-900/95 backdrop-blur-md border border-cyan-500/50 rounded-xl shadow-2xl">
                     <span class="text-white font-black text-sm tracking-tight">{isEn ? r.enName : r.name}</span>
                     <span class="block text-[9px] text-cyan-400 font-bold uppercase tracking-widest">{t('home.console.node.active')}</span>
                   </div>
                </div>
              </div>

              <!-- Word Cloud Effect -->
              <div class="absolute inset-0 pointer-events-none">
                {r.policies.map((p, idx) => (
                  <div
                    class={`absolute whitespace-nowrap font-black tracking-tighter transition-all duration-700 transform opacity-30 group-hover/node:opacity-100 group-hover/node:scale-110`}
                    style={`
                      left: ${p.x}px; 
                      top: ${p.y}px; 
                      font-size: ${p.weight * 0.85}rem;
                      color: ${idx % 2 === 0 ? '#22d3ee' : '#cbd5e1'};
                      text-shadow: ${idx % 2 === 0 ? '0 0 10px rgba(34,211,238,0.3)' : 'none'};
                      animation: float ${4 + idx}s ease-in-out infinite alternate;
                      animation-delay: ${idx * 0.3}s;
                    `}
                  >
                    {isEn ? p.enName : p.name}
                  </div>
                ))}
              </div>
            </a>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Data Legend & HUD Indicators -->
  <div class="absolute bottom-10 left-12 right-12 flex justify-between items-end z-30 pointer-events-none">
    <div class="flex gap-8 items-center bg-slate-900/40 backdrop-blur-md border border-slate-800/50 px-6 py-4 rounded-2xl pointer-events-auto">
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 rounded-full bg-cyan-400 shadow-[0_0_8px_rgba(34,211,238,0.6)]"></div>
        <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
          {t('home.console.legend.financial')}
        </div>
      </div>
      <div class="w-[1px] h-4 bg-slate-800"></div>
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 rounded-full bg-slate-400"></div>
        <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
          {t('home.console.legend.regulatory')}
        </div>
      </div>
    </div>
    
    <div class="flex flex-col items-end gap-2 text-right opacity-40">
       <div class="text-slate-500 text-[9px] font-bold font-mono tracking-tighter uppercase">
         SCAN_COORD: 39.9042N | 116.4074E
       </div>
       <div class="flex items-center gap-1">
         {[...Array(5)].map((_, i) => (
           <div class={`w-3 h-1 bg-cyan-500/${20 * (i + 1)}`}></div>
         ))}
       </div>
    </div>
  </div>

  <!-- Scanning Line Effect -->
  <div class="absolute inset-0 pointer-events-none z-40 overflow-hidden opacity-[0.05]">
    <div class="w-full h-[150px] bg-gradient-to-b from-transparent via-cyan-500 to-transparent -translate-y-full animate-[scan_10s_linear_infinite]"></div>
  </div>
</div>

<style>
  @keyframes float {
    from {
      transform: translateY(0px) rotate(-1deg);
    }
    to {
      transform: translateY(-10px) rotate(1deg);
    }
  }

  @keyframes scan {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(500%); }
  }

  /* Responsive Fixes */
  @media (max-width: 1024px) {
    .aspect-\[2\.4\/1\] {
      aspect-ratio: 1.8/1;
    }
  }
</style>
