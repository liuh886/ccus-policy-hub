# --- Core Build & Runtime ---
dist/
.astro/
node_modules/
.env
.env.production
.env.local
.env.*.local

# --- OS & IDE Junk ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log
pnpm-debug.log*
.eslintcache
*.tmp

# --- Lean Architecture: Archive & Tests ---
/archive/
!governance/archive/
!governance/archive/**

# --- Internal AI Context ---
.gemini/
.codex/
skills/
*.skill
.worktrees/

# --- CCUS AI Agent Governance (Workspace) ---
# Ignore the agent directory by default
agent/

# Un-ignore the core skill code and constitution
!agent/ccus-ai-agent/
!agent/ccus-ai-agent/SKILL.md
!agent/ccus-ai-agent/DESIGN.md
!agent/ccus-ai-agent/TASKS.md
!agent/ccus-ai-agent/AGENTS.md
!agent/ccus-ai-agent/logic/
!agent/ccus-ai-agent/logic/*.mjs

# Keep the schema but ignore the actual master database and locks
!agent/ccus-ai-agent/db/
!agent/ccus-ai-agent/db/schema.sql
agent/ccus-ai-agent/db/*.sqlite
agent/ccus-ai-agent/db/.lock

# Ignore transient governance reports and archives
agent/ccus-ai-agent/governance/reports/*
agent/ccus-ai-agent/governance/archive/*

# --- Background Tasks ---
tasks/

# --- Absolute Entry Points (Must be tracked) ---
!agent.md
!README.md
!README.zh.md
