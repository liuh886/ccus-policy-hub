---
import ThemeToggle from './ThemeToggle.astro';
import LanguagePicker from './LanguagePicker.astro';
import { ui, defaultLang } from '../i18n/ui';

const lang = Astro.currentLocale || defaultLang;
const t = (key: keyof (typeof ui)['zh']) =>
  ui[lang as keyof typeof ui][key] || ui[defaultLang][key];

const BASE = '/ccus-policy-hub';
const prefix = lang === 'zh' ? BASE : `${BASE}/${lang}`;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
  { name: t('nav.home'), href: `${prefix}/` },
  { name: t('nav.policy'), href: `${prefix}/policy/` },
  { name: t('nav.map'), href: `${prefix}/facilities/` },
  { name: t('nav.compare'), href: `${prefix}/compare/` },
  { name: t('nav.docs'), href: `${prefix}/docs/` },
].map((item) => {
  const normalizedHref = item.href.replace(/\/$/, '');
  const homePath = prefix.replace(/\/$/, '');
  const active =
    normalizedHref === homePath
      ? currentPath === homePath
      : currentPath === normalizedHref ||
        currentPath.startsWith(`${normalizedHref}/`);
  return { ...item, active };
});
---

<header class="site-header">
  <div class="site-nav-shell flex items-center justify-between gap-5">
    <a href={`${prefix}/`} class="site-logo" aria-label="CCUS Policy Hub home">
      <img src={`${BASE}/logo_optimized.svg`} alt="CCUS Policy Hub" />
    </a>

    <nav
      class="hidden md:flex items-center gap-1"
      aria-label="Primary navigation"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="site-nav-link"
            aria-current={item.active ? 'page' : undefined}
          >
            {item.name}
          </a>
        ))
      }
      <div
        class="ml-3 flex items-center gap-1 border-l border-slate-200 pl-3 dark:border-slate-700"
      >
        <a
          href={`${prefix}/search/`}
          class="site-icon-button"
          aria-label={t('nav.search')}
          title={t('nav.search')}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="19"
            height="19"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </a>
        <LanguagePicker />
        <ThemeToggle />
      </div>
    </nav>

    <button
      id="mobile-menu-toggle"
      class="site-icon-button md:hidden"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="23"
        height="23"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="4" x2="20" y1="7" y2="7"></line>
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="17" y2="17"></line>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="site-mobile-menu hidden md:hidden">
    <nav
      class="mx-auto flex max-w-screen-xl flex-col gap-1 p-4"
      aria-label="Mobile navigation"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="site-nav-link w-full justify-between"
            aria-current={item.active ? 'page' : undefined}
          >
            {item.name}
            {item.active && (
              <span class="h-1.5 w-1.5 rounded-full bg-teal-600" />
            )}
          </a>
        ))
      }
      <div
        class="mt-3 flex items-center justify-between border-t border-slate-200 pt-4 dark:border-slate-700"
      >
        <a href={`${prefix}/search/`} class="site-nav-link gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="19"
            height="19"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          {t('nav.search')}
        </a>
        <div class="flex items-center gap-1">
          <LanguagePicker />
          <ThemeToggle />
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  if (!(window as any).__ccusNavBarBound) {
    const closeMobileMenu = () => {
      const menu = document.getElementById('mobile-menu');
      const toggle = document.getElementById('mobile-menu-toggle');
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    };

    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      const toggle = target?.closest('#mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const button = document.getElementById('mobile-menu-toggle');

      if (toggle) {
        const willOpen = menu?.classList.contains('hidden') ?? true;
        menu?.classList.toggle('hidden');
        button?.setAttribute('aria-expanded', String(willOpen));
        return;
      }

      if (target?.closest('#mobile-menu a')) closeMobileMenu();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMobileMenu();
    });

    document.addEventListener('astro:after-swap', closeMobileMenu);
    (window as any).__ccusNavBarBound = true;
  }
</script>
