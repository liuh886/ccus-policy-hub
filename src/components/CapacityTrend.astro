          class="absolute w-full appearance-none bg-transparent pointer-events-none z-20 h-2 cursor-pointer
                 [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:w-4 [&::-webkit-slider-thumb]:h-4 [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-white [&::-webkit-slider-thumb]:border-2 [&::-webkit-slider-thumb]:border-blue-500 [&::-webkit-slider-thumb]:shadow-[0_0_8px_rgba(37,99,235,0.4)] [&::-webkit-slider-thumb]:transition-transform [&::-webkit-slider-thumb]:hover:scale-125
                 [&::-moz-range-thumb]:appearance-none [&::-moz-range-thumb]:pointer-events-auto [&::-moz-range-thumb]:w-4 [&::-moz-range-thumb]:h-4 [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:bg-white [&::-moz-range-thumb]:border-2 [&::-moz-range-thumb]:border-blue-500 [&::-moz-range-thumb]:shadow-[0_0_8px_rgba(37,99,235,0.4)] [&::-moz-range-thumb]:transition-transform [&::-moz-range-thumb]:hover:scale-125"
        />
        <input
          type="range"
          id="maxYearSlider"
          min="1970"
          max="2040"
          value="2030"
          class="absolute w-full appearance-none bg-transparent pointer-events-none z-20 h-2 cursor-pointer
                 [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:pointer-events-auto [&::-webkit-slider-thumb]:w-4 [&::-webkit-slider-thumb]:h-4 [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-white [&::-webkit-slider-thumb]:border-2 [&::-webkit-slider-thumb]:border-blue-500 [&::-webkit-slider-thumb]:shadow-[0_0_8px_rgba(37,99,235,0.4)] [&::-webkit-slider-thumb]:transition-transform [&::-webkit-slider-thumb]:hover:scale-125
                 [&::-moz-range-thumb]:appearance-none [&::-moz-range-thumb]:pointer-events-auto [&::-moz-range-thumb]:w-4 [&::-moz-range-thumb]:h-4 [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:bg-white [&::-moz-range-thumb]:border-2 [&::-moz-range-thumb]:border-blue-500 [&::-moz-range-thumb]:shadow-[0_0_8px_rgba(37,99,235,0.4)] [&::-moz-range-thumb]:transition-transform [&::-moz-range-thumb]:hover:scale-125"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] gap-4 relative z-10">
      <aside
        id="capacityTypeFilter"
        class="rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50/70 dark:bg-slate-950/30 px-3 py-3"
      >
        <div
          class="text-[9px] font-black uppercase tracking-widest text-slate-500 dark:text-slate-400 mb-2"
        >
          {text.typeFilterTitle}
        </div>
        <div class="space-y-1.5">
          {
            typeOptions.map((option) => (
              <label
                for={`capacity-type-${option.id}`}
                class="flex items-center gap-1.5 text-[10px] font-bold text-slate-600 dark:text-slate-300 cursor-pointer select-none"
              >
                <input
                  id={`capacity-type-${option.id}`}
                  type="checkbox"
                  value={option.id}
                  checked
                  data-capacity-type
                  class="h-3 w-3 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500"
                />
                <span>{option.label}</span>
