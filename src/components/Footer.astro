---
import { ui, defaultLang } from '../i18n/ui';

interface Props {
  lang?: string;
}

const { lang = defaultLang } = Astro.props;
const t = (key: keyof (typeof ui)['zh']) =>
  ui[lang as keyof typeof ui][key] || ui[defaultLang][key];

const BASE = '/ccus-policy-hub';
const prefix = lang === 'zh' ? BASE : `${BASE}/${lang}`;
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-shell">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-[1.5fr_1fr_1fr]">
      <div class="max-w-md">
        <img
          src={`${BASE}/logo_optimized.svg`}
          alt="CCUS Policy Hub"
          class="mb-5 h-12 w-auto"
          loading="lazy"
        />
        <p class="text-sm leading-6 text-slate-500 dark:text-slate-400">
          {t('footer.description')}
        </p>
        <div class="mt-5 flex flex-wrap gap-2 text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500 dark:text-slate-400">
          <span class="rounded-md border border-slate-200 px-2.5 py-1 dark:border-slate-700">Open data</span>
          <span class="rounded-md border border-slate-200 px-2.5 py-1 dark:border-slate-700">Traceable sources</span>
          <span class="rounded-md border border-slate-200 px-2.5 py-1 dark:border-slate-700">Bilingual</span>
        </div>
      </div>

      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-[0.16em] text-slate-900 dark:text-white">
          {t('footer.links')}
        </h4>
        <ul class="space-y-3 text-sm">
          <li><a href={`${prefix}/policy/`}>{t('nav.policy')}</a></li>
          <li><a href={`${prefix}/facilities/`}>{t('nav.map')}</a></li>
          <li><a href={`${prefix}/compare/`}>{t('nav.compare')}</a></li>
          <li><a href={`${prefix}/docs/`}>{t('nav.docs')}</a></li>
          <li><a href={`${prefix}/changelog/`}>Changelog</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-[0.16em] text-slate-900 dark:text-white">
          {t('footer.contact')}
        </h4>
        <p class="mb-5 text-sm leading-6 text-slate-600 dark:text-slate-400">
          {t('footer.contact_info')}
        </p>
        <a
          href={`${prefix}/legal/`}
          class="inline-flex items-center gap-2 text-xs font-semibold"
        >
          Legal & Privacy
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-slate-200 pt-6 text-xs text-slate-500 dark:border-slate-700 dark:text-slate-500 sm:flex-row sm:items-center sm:justify-between">
      <span>&copy; {currentYear} CCUS Policy Hub.</span>
      <span>Open-source intelligence for global CCUS policies and projects.</span>
    </div>
  </div>
</footer>
