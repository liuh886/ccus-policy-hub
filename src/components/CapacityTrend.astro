    <div class="absolute top-6 right-8 flex gap-1.5 opacity-30">
      <div class="w-1 h-6 bg-blue-500 animate-[bounce_2s_infinite]"></div>
      <div class="w-1 h-3 bg-blue-500 animate-[bounce_2s_infinite_0.2s]"></div>
      <div class="w-1 h-4 bg-blue-500 animate-[bounce_2s_infinite_0.4s]"></div>
    </div>

    <div class="flex justify-between items-start mb-4 relative z-10">
      <div>
        <h3
          class="text-lg font-black dark:text-white mb-1 uppercase tracking-tight"
