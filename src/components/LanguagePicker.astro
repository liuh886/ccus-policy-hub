---
import { languages } from '../i18n/ui';
const currentLang = Astro.currentLocale || 'zh';
const pathname = Astro.url.pathname;
const BASE = '/ccus-policy-hub';
---

<div
  class="flex h-10 items-center gap-0.5 rounded-[10px] border border-slate-200 bg-slate-50 p-1 dark:border-slate-700 dark:bg-slate-800"
  aria-label="Language selector"
>
  {
    Object.entries(languages).map(([lang, label]) => {
      let href = pathname;
      const pathWithoutBase =
        (pathname.startsWith(BASE) ? pathname.slice(BASE.length) : pathname) ||
        '/';

      if (lang === 'en') {
        if (!pathWithoutBase.startsWith('/en')) {
          href = `${BASE}/en${pathWithoutBase === '/' ? '/' : pathWithoutBase}`;
          if (!href.endsWith('/')) href += '/';
        }
      } else if (pathWithoutBase.startsWith('/en')) {
        href = `${BASE}${pathWithoutBase.replace('/en', '') || '/'}`;
        if (!href.endsWith('/')) href += '/';
      } else {
        href = `${BASE}${pathWithoutBase}`;
        if (!href.endsWith('/')) href += '/';
      }

      return (
        <a
          href={href}
          lang={lang}
          aria-current={currentLang === lang ? 'true' : undefined}
          class={`inline-flex h-8 min-w-8 items-center justify-center rounded-md px-2 text-[10px] font-bold uppercase tracking-[0.08em] transition-all ${
            currentLang === lang
              ? 'bg-white text-teal-700 shadow-sm dark:bg-slate-700 dark:text-teal-300'
              : 'text-slate-500 hover:text-teal-700 dark:text-slate-400 dark:hover:text-teal-300'
          }`}
        >
          {label}
        </a>
      );
    })
  }
</div>
